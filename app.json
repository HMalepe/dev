{
  "expo": {
    "name": "Spaza POS",
    "slug": "spaza-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "spaza-pos",
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.spazapos.app"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spazapos.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Spaza POS needs camera access to scan product barcodes."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Spaza POS needs camera access to scan product barcodes."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
