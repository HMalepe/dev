# ============================================
# VouchSA - Environment Configuration
# ============================================
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. NEVER commit .env to git (it's in .gitignore)
#
# WHERE TO GET THESE VALUES:
# See docs/GETTING_STARTED.md for step-by-step instructions.
# ============================================

# --- Supabase ---
# Get from: app.supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-here

# --- Google Maps ---
# Get from: console.cloud.google.com → APIs → Credentials
GOOGLE_MAPS_API_KEY=AIza...your-key-here

# --- Yoco Payment ---
# Get from: yoco.com → Dashboard → Developers → API Keys
YOCO_PUBLIC_KEY=pk_test_...your-public-key
YOCO_SECRET_KEY=sk_test_...your-secret-key

# --- Firebase (Push Notifications) ---
# Get from: console.firebase.google.com → Project Settings
# Note: You also need google-services.json (Android) and
# GoogleService-Info.plist (iOS) in the app directories.
# See docs/GETTING_STARTED.md Step 4 for details.
