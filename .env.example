# Copy this file to `.env` and fill in the values you need.
# Nothing here is required to try the pipeline locally: without an OpenAI key,
# content is generated from offline templates; without platform credentials,
# posts are saved as drafts / run through the "mock" platform.

# --- AI content generation ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Twitter / X ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Pipeline behavior ---
# When true, generated content is published immediately instead of saved as a draft.
PIPELINE_AUTO_APPROVE=false
# When true (default), platform adapters simulate publishing instead of calling
# real APIs. Set to false once you're ready to post for real.
PIPELINE_DRY_RUN=true
