# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# --- Phase 0: Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 1+: Claude API agents (research/draft/QA) ---
ANTHROPIC_API_KEY=
# Optional: override the model used by the QA agent (lib/agents/qa). Defaults
# to claude-sonnet-4-5 if unset.
ANTHROPIC_QA_MODEL=

# --- Phase 5: YouTube publishing ---
# Google Cloud OAuth 2.0 client (Desktop app type) with the YouTube Data
# API v3 enabled. YOUTUBE_REFRESH_TOKEN comes from running the OAuth
# consent flow once, locally, by hand -- see README's one-time setup
# steps. Never expires unless revoked.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Phase 5: Instagram publishing ---
# Meta app + Instagram Business/Creator account linked to a Facebook Page.
# INSTAGRAM_ACCESS_TOKEN is only the *initial* long-lived (60-day) token
# from the one-time Facebook Login consent flow -- it seeds the
# platform_tokens table on first use, after which the weekly
# refresh-ig-token cron keeps the table's copy fresh and this env var is
# no longer read. INSTAGRAM_APP_ID/SECRET are required for that refresh
# (Meta's fb_exchange_token endpoint needs them), not just the initial
# consent flow -- these weren't in the original Phase 0 env var list but
# are unavoidable for the token-refresh cron the Phase 5 brief itself asks
# for. INSTAGRAM_BUSINESS_ACCOUNT_ID is the {ig-user-id} every publish/
# status-check call is scoped to.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Phase 5: TikTok publishing ---
# Content Posting API app registration (should have been submitted for
# audit back in Phase 0 -- if it wasn't, flag this back immediately, audit
# turnaround is a 1-6 week external clock). TIKTOK_ACCESS_TOKEN/
# TIKTOK_REFRESH_TOKEN are the *initial* tokens from the one-time OAuth
# consent flow -- like Instagram's token, they only seed the
# platform_tokens table on first use; the daily refresh-tiktok-token cron
# takes over from there (TikTok rotates the refresh_token on every
# refresh, so the table, not this env var, is the durable source of
# truth). TIKTOK_AUDITED is "true"/"false", flipped manually once TikTok
# approves the app -- the TikTok publish agent branches its entire
# behavior on this flag (see README). Also requires verifying your
# Supabase Storage domain as a URL property in the TikTok Developer portal
# (needed for the PULL_FROM_URL publish method -- see README).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_AUDITED=

# --- Phase 3: Voice/video asset generation ---
ELEVENLABS_API_KEY=
# Voice ID from your ElevenLabs account, set to a calm/measured preset (see
# README for how to pick one). Required for the voiceover agent.
ELEVENLABS_VOICE_ID=
# Defaults to eleven_multilingual_v2 if unset.
ELEVENLABS_MODEL_ID=
# Pay-as-you-go per-1,000-character rate for your ElevenLabs plan tier, used
# for agent_logs.cost_usd (character-based, not token-based). ElevenLabs'
# per-character rate varies by plan (see README) -- set this to match yours.
# Defaults to 0.10 (a typical Multilingual v2 pay-as-you-go rate) if unset.
ELEVENLABS_COST_PER_1K_CHARS_USD=

# Video assembly (Shotstack). Set SHOTSTACK_STAGE=v1 for production renders
# (no watermark, billed) or =stage for the free sandbox (watermarked -- do
# not use for anything actually published). Defaults to v1.
SHOTSTACK_API_KEY=
SHOTSTACK_STAGE=
# Per-minute rate for your Shotstack plan, used for agent_logs.cost_usd.
# Defaults to 0.30 (pay-as-you-go) if unset; set to 0.20 if you're on the
# $39/mo subscription tier instead.
SHOTSTACK_COST_PER_MINUTE_USD=

# AI B-roll clips (used sparingly, 2-3 short clips per episode, generic/
# non-identifying content only -- see docs/asset-pipeline-safety.md). Off by
# default; the pipeline runs fine on Pexels images alone. Implemented against
# fal.ai's hosted Kling endpoint (see README for why fal.ai specifically --
# "the Kling API" has no single canonical public spec).
KLING_API_KEY=
ENABLE_KLING_BROLL=
KLING_FAL_MODEL_ID=

# Stock/generic imagery (Pexels, free tier is sufficient at this volume).
PEXELS_API_KEY=

# Secures every app/api/cron/* route (check-renders, weekly-review, and, as
# of Phase 5, publish-scheduled + refresh-ig-token + refresh-tiktok-token)
# against public invocation. Vercel sets this automatically as a project env
# var and sends it as a Bearer token when it triggers any of these cron jobs
# -- see README for local-testing instructions.
CRON_SECRET=

# Optional: pin the Meta Graph API version used by the Instagram integration
# (lib/integrations/instagram.ts). Defaults to a recent stable version if
# unset -- bump this if Meta deprecates it (check the Graph API changelog).
META_GRAPH_API_VERSION=
